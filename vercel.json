{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "login.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "register.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "user/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}